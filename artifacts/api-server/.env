# Local Development Environment Variables
# Generated for local testing - replace with your actual values

# Database (Required) - Using a local PostgreSQL or create a free Neon database
DATABASE_URL=postgresql://user:password@localhost:5432/alphavest

# Session Secret (Required) - Random 32+ character string
SESSION_SECRET=local-dev-secret-change-this-in-production-minimum-32-chars

# Environment
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# App Domain (for WebAuthn/Biometric Login)
APP_DOMAIN=localhost
APP_ORIGIN=http://localhost:5173

# Payment Gateways (Optional - leave empty for local dev)
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=
# MONNIFY_API_KEY=
# MONNIFY_SECRET_KEY=
# MONNIFY_CONTRACT_CODE=
# MONNIFY_BASE_URL=

# Email (Optional - leave empty for local dev)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Google OAuth (Optional - leave empty for local dev)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# Cloudinary (Required for KYC document uploads)
# Sign up at https://cloudinary.com to get these credentials
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
